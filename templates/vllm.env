# vllm.env — systemd EnvironmentFile for vLLM service
# Generated by vllm-thor. Edit values then: sudo systemctl restart vllm
# To regenerate: vllm-thor install   or   vllm-thor setup

# ── Model selection ───────────────────────────────────────────────────────────
# Change to switch models without reinstalling:
#   sed -i 's|^SERVE_MODEL=.*|SERVE_MODEL=Qwen/Qwen3-VL-32B-Instruct|' vllm.env
#   sudo systemctl restart vllm
SERVE_MODEL=${SERVE_MODEL}
CACHE_ROOT=${CACHE_ROOT}

# ── CUDA ──────────────────────────────────────────────────────────────────────
CUDA_HOME=${CUDA_HOME}
TRITON_PTXAS_PATH=${CUDA_HOME}/bin/ptxas
TRITON_PTXAS_BLACKWELL_PATH=${CUDA_HOME}/bin/ptxas
# Additional Triton toolchain paths — required for JIT kernel compilation
TRITON_CUDART_PATH=${CUDA_HOME}/include
TRITON_CUDACRT_PATH=${CUDA_HOME}/include
TRITON_CUPTI_PATH=${CUDA_HOME}/include
TRITON_NVDISASM_PATH=${CUDA_HOME}/bin/nvdisasm
TRITON_CUOBJDUMP_PATH=${CUDA_HOME}/bin/cuobjdump
PATH=${CUDA_HOME}/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
LD_LIBRARY_PATH=${CUDA_HOME}/lib64
# Linker stub path — needed for CUDA extension builds
LIBRARY_PATH=${CUDA_HOME}/lib64/stubs
TORCH_CUDA_ARCH_LIST=${TORCH_CUDA_ARCH}
DG_JIT_USE_NVRTC=1

# ── vLLM runtime ─────────────────────────────────────────────────────────────
# NVFP4 on Thor (SM110):
#   - SM110 patch must be applied (patches/patch_sm110.py) for CUTLASS FP4 backend.
#     Without it, NVFP4 falls back to Marlin (40-60% slower).
#   - Triton attention backend works fine on SM110 (regular kernels, not FP4 GEMM).
#   - Triton MXFP4 GEMM kernels target (9,0) <= cap < (11,0); SM110=(11,0) is
#     already excluded upstream — no action needed.
#   - If MoE throughput is unexpectedly low on your vLLM version, try:
#     VLLM_USE_FLASHINFER_MOE_FP4=0  (uncomment below)
# VLLM_USE_FLASHINFER_MOE_FP4=0
VLLM_WORKER_MULTIPROC=0
VLLM_ENABLE_V1_MULTIPROCESSING=0
VLLM_PLUGINS=
VLLM_LOGGING_LEVEL=INFO
VLLM_NO_USAGE_STATS=1

# ── Privacy / output ─────────────────────────────────────────────────────────
DO_NOT_TRACK=1
PYTHONUNBUFFERED=1
SAFETENSORS_FAST_GPU=1

# ── GPU visibility ────────────────────────────────────────────────────────────
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility,graphics
CUDA_VISIBLE_DEVICES=0

# ── HuggingFace token ─────────────────────────────────────────────────────────
# Set securely via: sudo systemctl edit vllm
# then add: [Service]
#           Environment=HF_TOKEN=hf_xxxxxxxxxxxx
HF_TOKEN=

# ── Cache dirs ────────────────────────────────────────────────────────────────
VLLM_CACHE_ROOT=${VLLM_CACHE_ROOT}
VLLM_ASSETS_CACHE=${VLLM_ASSETS_CACHE}
VLLM_TUNED_CONFIG_FOLDER=${VLLM_TUNED_CONFIG_FOLDER}
FLASHINFER_JIT_DIR=${FLASHINFER_JIT_DIR}
TRITON_CACHE_DIR=${TRITON_CACHE_DIR}
TORCHINDUCTOR_CACHE_DIR=${TORCHINDUCTOR_CACHE_DIR}
TORCH_COMPILE_CACHE_DIR=${TORCH_COMPILE_CACHE_DIR}
XDG_CACHE_HOME=${XDG_CACHE_HOME}
# tiktoken: three vars cover all tiktoken versions
TIKTOKEN_CACHE_DIR=${TIKTOKEN_ENCODINGS_BASE}
TIKTOKEN_ENCODINGS_BASE=${TIKTOKEN_ENCODINGS_BASE}
TIKTOKEN_RS_CACHE_DIR=${TIKTOKEN_RS_CACHE_DIR}
