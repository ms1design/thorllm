#!/bin/bash
# =============================================================================
# thorllm — CLI entry point
# Usage: thorllm <command> [options]
# =============================================================================
set -euo pipefail

SELF_DIR="$(cd "$(dirname "$(realpath "${BASH_SOURCE[0]}")")/.."; pwd)"
LIB_DIR="${SELF_DIR}/lib"
TPL_DIR="${SELF_DIR}/templates"
export SELF_DIR LIB_DIR TPL_DIR

# shellcheck source=lib/common.sh
source "${LIB_DIR}/common.sh"
source "${LIB_DIR}/config.sh"

# ── Load VERSION ──────────────────────────────────────────────────────────────
VERSION=$(cat "${SELF_DIR}/VERSION")

VENV_PATH="${VENV_PATH:-${BUILD_PATH:-~/thorllm}/.vllm}"
if [[ -x "${VENV_PATH}/bin/python" ]]; then
    VLLM_VERSION_INSTALLED=$(
        "${VENV_PATH}/bin/python" -c \
            "import importlib.metadata as m; print(m.version('vllm'))" 2>/dev/null || echo ""
    )
fi

# ── Usage ─────────────────────────────────────────────────────────────────────
usage() {
    usage_logo
    cat <<EOF
thorllm ${VERSION}${VLLM_VERSION_INSTALLED:+ — vLLM ${VLLM_VERSION_INSTALLED}} — vLLM manager for NVIDIA Jetson Thor

Usage:
  thorllm <command> [options]

Install:
  setup                  Interactive TUI setup wizard
  install                Run full install (non-interactive, uses config)
  install --update       Update vLLM to latest version
  reconfigure            Regenerate vllm.env + launcher from current templates
                         (use after 'git pull' to apply env fixes without reinstalling)

Service:
  start [-p PORT]        Start the vLLM service
  stop                   Stop the vLLM service
  restart [-p PORT]      Restart the vLLM service
  status                 Show service status
  kill                   Force-kill vLLM and free GPU memory
  logs [-f]              Show service logs (use -f to follow)

Models  (opens TUI when no subcommand given):
  model                  Open interactive TUI model manager
  model list             List available model configs
  model add <org/name>   Create a new model config from template
  model switch <name>    Switch the active model
  model select           Interactive model selection (TUI)
  model show <name>      Print the model config YAML
  model edit <name>      Open model config in \$EDITOR

Info:
  version                Show installed vLLM and dependency versions
  config                 Show current configuration

System:
  uninstall              Remove thorllm and all installed components
  completion             Print TAB-completion setup instructions

Options:
  -h, --help             Show this help (also accepted after any command)
  --no-color             Disable colour output
  --build-path <path>    Override BUILD_PATH (default: ~/thorllm)
  -p, --port <port>      Port for vLLM API server (used with start/restart)

Environment:
  BUILD_PATH             Installation directory  (default: ~/thorllm)
  CACHE_ROOT             Cache root directory    (default: ~/.cache/vllm)
  SERVE_MODEL            Active model            (default: openai/gpt-oss-120b)
  VLLM_PORT              API port                (default: 8000)
  HF_TOKEN               HuggingFace access token

Examples:
  thorllm setup
  thorllm start --port 9000
  thorllm model                          # open TUI model manager
  thorllm model add Qwen/Qwen3-VL-32B-Instruct
  thorllm logs -f
  thorllm kill
EOF
}

# ── Argument parsing ──────────────────────────────────────────────────────────
[[ $# -eq 0 ]] && { usage; exit 0; }

FOLLOW_LOGS=0
UPDATE=0
CMD=""
SUBCMD=""
MODEL_ARG=""

# Scan for global flags first; anything that looks like a command breaks the loop
while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            # Accept -h/--help anywhere in the command line — always shows usage
            usage; exit 0
            ;;
        --no-color)
            NO_COLOR=1; shift
            ;;
        --build-path)
            BUILD_PATH="$2"; shift 2
            ;;
        --update)
            UPDATE=1; shift
            ;;
        -p|--port)
            export VLLM_PORT="$2"; shift 2
            ;;
        setup)    CMD=setup;         shift ;;
        install)  CMD=install;       shift ;;
        reconfigure) CMD=reconfigure; shift ;;
        start)    CMD=start;       shift ;;
        stop)     CMD=stop;        shift ;;
        restart)  CMD=restart;     shift ;;
        status)   CMD=status;      shift ;;
        kill)     CMD=kill;        shift ;;
        version)  CMD=version;     shift ;;
        config)   CMD=config_show; shift ;;
        uninstall) CMD=uninstall;  shift ;;
        completion) CMD=completion; shift ;;
        logs)
            CMD=logs; shift
            [[ "${1:-}" == "-f" ]] && { FOLLOW_LOGS=1; shift; } || true
            ;;
        model)
            CMD=model
            # Peek at next token: may be subcommand, flag, or nothing
            shift
            case "${1:-}" in
                -h|--help|"")
                    # thorllm model -h  →  same as thorllm model (no subcommand)
                    SUBCMD=""
                    [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && shift || true
                    ;;
                list|add|switch|show|edit|select)
                    SUBCMD="$1"; shift
                    # Grab the model name argument if present (not a flag)
                    if [[ $# -gt 0 && ! "$1" =~ ^- ]]; then
                        MODEL_ARG="$1"; shift
                    fi
                    ;;
                *)
                    # Unknown subcommand — will be caught in dispatch
                    SUBCMD="$1"; shift
                    ;;
            esac
            ;;
        *)
            die "Unknown command: $1. Run 'thorllm --help'"
            ;;
    esac
done

# ── Dispatch ──────────────────────────────────────────────────────────────────
case "${CMD:-}" in
    setup)
        source "${SELF_DIR}/tui/wizard.sh"
        run_wizard
        ;;
    install)
        source "${LIB_DIR}/install.sh"
        run_install "${UPDATE}"
        ;;
    reconfigure)
        source "${LIB_DIR}/service.sh"
        run_reconfigure
        ;;
    start|stop|restart|status)
        source "${LIB_DIR}/service.sh"
        service_ctl "${CMD}"
        ;;
    kill)
        source "${LIB_DIR}/service.sh"
        service_kill
        ;;
    logs)
        source "${LIB_DIR}/service.sh"
        service_logs "${FOLLOW_LOGS}"
        ;;
    model)
        source "${LIB_DIR}/model.sh"
        case "${SUBCMD:-}" in
            list)
                model_list
                ;;
            add)
                [[ -z "${MODEL_ARG}" ]] && die "Usage: thorllm model add <org/name>"
                model_add "${MODEL_ARG}"
                ;;
            switch)
                [[ -z "${MODEL_ARG}" ]] && die "Usage: thorllm model switch <org/name>"
                model_switch "${MODEL_ARG}"
                ;;
            show)
                [[ -z "${MODEL_ARG}" ]] && die "Usage: thorllm model show <org/name>"
                model_show "${MODEL_ARG}"
                ;;
            edit)
                [[ -z "${MODEL_ARG}" ]] && die "Usage: thorllm model edit <org/name>"
                model_edit "${MODEL_ARG}"
                ;;
            select)
                source "${SELF_DIR}/tui/wizard.sh"
                _model_select_interactive
                ;;
            "")
                # No subcommand (or -h was given) — open TUI model manager
                source "${SELF_DIR}/tui/wizard.sh"
                model_manage_interactive
                ;;
            *)
                die "Unknown model subcommand: '${SUBCMD}'. Options: list add switch select show edit"
                ;;
        esac
        ;;
    version)
        source "${LIB_DIR}/validate.sh"
        show_versions
        ;;
    config_show)
        source "${LIB_DIR}/config.sh"
        config_show
        ;;
    uninstall)
        source "${LIB_DIR}/uninstall.sh"
        run_uninstall
        ;;
    completion)
        source "${LIB_DIR}/completion.sh"
        thorllm_completion_install_hint
        ;;
    *)
        usage; exit 1
        ;;
esac
