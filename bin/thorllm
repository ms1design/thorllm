#!/bin/bash
# =============================================================================
# vllm-thor — CLI entry point
# Usage: vllm-thor <command> [options]
# =============================================================================
set -euo pipefail

SELF_DIR="$(cd "$(dirname "$(realpath "${BASH_SOURCE[0]}")")/.." && pwd)"
LIB_DIR="${SELF_DIR}/lib"
TPL_DIR="${SELF_DIR}/templates"

# shellcheck source=lib/common.sh
source "${LIB_DIR}/common.sh"
source "${LIB_DIR}/config.sh"

# ── Load user config if it exists ────────────────────────────────────────────
CONFIG_FILE="${CONFIG_FILE:-${BUILD_PATH}/vllm-thor.conf}"
[[ -f "${CONFIG_FILE}" ]] && config_load "${CONFIG_FILE}"

VERSION="0.1.0"

usage() {
    usage_logo
    echo ""
    {
        echo "${CYAN}vllm-thor${NC} ${VERSION} — vLLM manager for NVIDIA Jetson Thor"
        echo ""
        echo "${CYAN}Usage:${NC}"
        echo "  vllm-thor <command> [options]"
        echo ""
        echo "${CYAN}Install:${NC}"
        echo "  setup                  Interactive TUI setup wizard"
        echo "  install                Run full install (non-interactive, uses config)"
        echo "  install --update       Update vLLM to latest version"
        echo ""
        echo "${CYAN}Service:${NC}"
        echo "  start                  Start the vLLM service"
        echo "  stop                   Stop the vLLM service"
        echo "  restart                Restart the vLLM service"
        echo "  status                 Show service status"
        echo "  logs [-f]              Show service logs (use -f to follow)"
        echo ""
        echo "${CYAN}Models:${NC}"
        echo "  model list             List available model configs"
        echo "  model add <org/name>   Create a new model config from template"
        echo "  model switch <org/name> Switch the active model"
        echo "  model select           Interactive model selection"
        echo "  model show <org/name>  Print the model config YAML"
        echo "  model edit <org/name>  Open model config in \$EDITOR"
        echo ""
        echo "${CYAN}Info:${NC}"
        echo "  version                Show installed vLLM and dependency versions"
        echo "  config                 Show current configuration"
        echo ""
        echo "${CYAN}System:${NC}"
        echo "  uninstall              Remove thorllm and all installed components"
        echo ""
        echo "${CYAN}Options:${NC}"
        echo "  -h, --help             Show this help"
        echo "  --no-color             Disable colour output"
        echo "  --build-path <path>    Override BUILD_PATH (default: ~/vllm-thor)"
        echo ""
        echo "${CYAN}Environment:${NC}"
        echo "  BUILD_PATH             Installation directory  (default: ~/vllm-thor)"
        echo "  CACHE_ROOT             Cache root directory    (default: ~/.cache/vllm)"
        echo "  SERVE_MODEL            Active model            (default: openai/gpt-oss-120b)"
        echo "  HF_TOKEN               HuggingFace access token"
        echo "  REPO_URL               vllm-thor repo URL (for updates)"
        echo ""
        echo "${CYAN}Examples:${NC}"
        echo "  vllm-thor setup"
        echo "  vllm-thor model add Qwen/Qwen3-VL-32B-Instruct"
        echo "  vllm-thor model switch Qwen/Qwen3-VL-32B-Instruct"
        echo "  vllm-thor restart"
        echo "  vllm-thor logs -f"
    }
}

# ── Argument parsing ──────────────────────────────────────────────────────────
[[ $# -eq 0 ]] && { usage; exit 0; }

FOLLOW_LOGS=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)     usage; exit 0 ;;
        --no-color)    NO_COLOR=1; shift ;;
        --build-path)  BUILD_PATH="$2"; shift 2 ;;
        --update)      UPDATE=1; shift ;;
        -f)            FOLLOW_LOGS=1; shift ;;
        setup)         CMD=setup; shift ;;
        install)       CMD=install; shift ;;
        start)         CMD=start; shift ;;
        stop)          CMD=stop; shift ;;
        restart)       CMD=restart; shift ;;
        status)        CMD=status; shift ;;
        logs)          CMD=logs; shift ;;
        model)
            CMD=model
            SUBCMD="${2:-}"
            MODEL_ARG="${3:-}"
            shift; [[ $# -gt 0 ]] && shift; [[ $# -gt 0 ]] && shift
            ;;
        version)       CMD=version; shift ;;
        config)        CMD=config_show; shift ;;
        uninstall)     CMD=uninstall; shift ;;
        *)             die "Unknown command: $1. Run 'vllm-thor --help'" ;;
    esac
done

# ── Dispatch ──────────────────────────────────────────────────────────────────
case "${CMD:-}" in
    setup)
        source "${SELF_DIR}/tui/wizard.sh"
        run_wizard
        ;;
    install)
        source "${LIB_DIR}/install.sh"
        run_install "${UPDATE:-0}"
        ;;
    start|stop|restart|status)
        source "${LIB_DIR}/service.sh"
        service_ctl "${CMD}"
        ;;
    logs)
        source "${LIB_DIR}/service.sh"
        service_logs "${FOLLOW_LOGS}"
        ;;
    model)
        source "${LIB_DIR}/model.sh"
        case "${SUBCMD:-}" in
            list)   model_list ;;
            add)    [[ -z "${MODEL_ARG}" ]] && die "Usage: vllm-thor model add <org/name>"
                    model_add "${MODEL_ARG}" ;;
            switch) [[ -z "${MODEL_ARG}" ]] && die "Usage: vllm-thor model switch <org/name>"
                    model_switch "${MODEL_ARG}" ;;
            show)   [[ -z "${MODEL_ARG}" ]] && die "Usage: vllm-thor model show <org/name>"
                    model_show "${MODEL_ARG}" ;;
            edit)   [[ -z "${MODEL_ARG}" ]] && die "Usage: vllm-thor model edit <org/name>"
                    model_edit "${MODEL_ARG}" ;;
            select) [[ -z "${MODEL_ARG}" ]] && { source "${SELF_DIR}/tui/wizard.sh"; _model_select_interactive; }
                    die "Usage: vllm-thor model select" ;;
            *)      die "Unknown model subcommand: '${SUBCMD}'. Options: list add switch show edit select" ;;
        esac
        ;;
    version)
        source "${LIB_DIR}/validate.sh"
        show_versions
        ;;
    config_show)
        source "${LIB_DIR}/config.sh"
        config_show
        ;;
    uninstall)
        source "${LIB_DIR}/uninstall.sh"
        run_uninstall
        ;;
    *)
        usage; exit 1
        ;;
esac
